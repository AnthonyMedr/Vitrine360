{
  "name": "vitrine360-central-comercial-digital",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "node scripts/clean-dist.mjs",
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview --host 127.0.0.1 --port 3000",
    "start": "vite preview --host 127.0.0.1 --port 3000",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:status": "node scripts/run-with-env.mjs .env scripts/db-status.mjs",
    "db:migrate": "node --env-file=.env scripts/db-migrate.mjs",
    "db:migrate:prod": "node scripts/run-with-env.mjs .env.production scripts/db-migrate.mjs",
    "db:seed": "node --env-file=.env scripts/db-seed.mjs",
    "db:seed:prod": "node scripts/run-with-env.mjs .env.production scripts/db-seed.mjs",
    "store:identity:sync": "node --env-file=.env scripts/sync-store-identity.mjs",
    "store:identity:sync:prod": "node scripts/run-with-env.mjs .env.production scripts/sync-store-identity.mjs",
    "db:reset": "docker compose down -v && docker compose up -d && node --env-file=.env scripts/db-migrate.mjs && node --env-file=.env scripts/db-seed.mjs",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "pilot:content:init": "node scripts/init-pilot-content-approval.mjs",
    "pilot:content:apply": "node --env-file=.env scripts/pilot-content-apply.mjs",
    "pilot:content:report": "node --env-file=.env scripts/pilot-content-report.mjs",
    "pilot:content:checklist": "node scripts/pilot-content-checklist.mjs",
    "production:env:init": "node scripts/init-production-env.mjs",
    "go-live:preflight": "node scripts/go-live-preflight.mjs",
    "go-live:report": "node scripts/go-live-status-report.mjs",
    "production:next": "node scripts/production-next-steps.mjs",
    "production:handoff": "node scripts/production-handoff-bundle.mjs",
    "production:check": "node scripts/run-with-env.mjs .env.production scripts/production-readiness.mjs",
    "production:check:local": "node scripts/run-with-env.mjs .env scripts/production-readiness.mjs PRODUCTION_CHECK_MODE=local",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test:e2e:desktop": "playwright test --project=chromium-desktop",
    "test:e2e:mobile": "playwright test --project=webkit-mobile",
    "test:e2e": "npm run test:e2e:desktop && npm run test:e2e:mobile",
    "test:e2e:install": "playwright install --with-deps"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-start": "^1.167.50",
    "@tanstack/router-plugin": "^1.167.28",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.575.0",
    "nitro": "3.0.260603-beta",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.6.5",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.16.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "prisma": "^7.8.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
